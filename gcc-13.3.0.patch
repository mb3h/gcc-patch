+/* Get difference naked line number removed effects of '#line'.  */
+
+int
+rich_location::calc_naked_line_delta ()
+{
+  /* a point of calculation */
+  location_t loc = get_range (0)->m_loc;
+
+  /* give up as unexpected */
+  if (m_line_table == NULL)
+    return 0;
+  const line_map_ordinary *last_map
+    = LINEMAPS_LAST_ORDINARY_MAP (m_line_table);
+  if (! (last_map && MAP_START_LOCATION (last_map) <= loc))
+    return 0;
+
+  /* get a map that includes the point */
+  const struct line_map_ordinary *map
+    = linemap_ordinary_map_lookup (m_line_table, loc);
+
+  /* naked line ('#line' not affected) */
+  int naked_start_line
+    = linemap_ordinary_map_calc_naked_start_line (m_line_table, map);
+  int offset_line
+    = ((loc - map->start_location) >> map->m_column_and_range_bits);
+
+  /* normal line ('#line' affected) */
+  int line = SOURCE_LINE (map, loc);
+
+  return naked_start_line + offset_line - line;
+}
