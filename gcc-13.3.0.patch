+/* Returns new 'location_t' value after changing bit-boundary between
+   'line' and 'column' of old 'location_t' value */
+static location_t
+location_change_line_lsb (location_t loc_old, unsigned int line_lsb_old,
+                          unsigned int line_lsb_new)
+{
+  /* Adjust bits layout. */
+  unsigned line
+    = loc_old >> line_lsb_old;
+  unsigned column_and_range
+    = loc_old & ((1U << line_lsb_old) -1);
+
+  linemap_assert (column_and_range < (1U << line_lsb_new));
+  location_t new_loc
+    = (line << line_lsb_new) | column_and_range;
+  return new_loc;
+}
