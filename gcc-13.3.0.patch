+/* Get naked line number removed effects of '#line'.
+
+   CONSTRAINT:
+   1. This omits thread-safe, because it expects available for the error
+      message only. If error_at() requires to be called without being
+      serialized among threads, it probably needs either of a) or b).
+
+      a) disable the code about caching and resuming.
+         (TRADEOFF: it might cause getting slow)
+      b) change the place for caching and resuming information from static
+         memory into stack/heap memory at any of functions that are called
+         by error_at().
+         (TRADEOFF: widely tuning cost about interface design)
+ */
+static int
+linemap_ordinary_map_calc_naked_start_line
+  (class line_maps *set, const struct line_map_ordinary *goal)
+{
+#if 1 /* caching & resuming (for performance) */
+  static struct
+  {
+    const char *to_file;
+    const line_map_ordinary *map;
+    unsigned total_counted;
+  } s_cache
+    = { NULL, NULL, 0 };
+#endif
+
+  const struct line_map_ordinary *begin
+    = LINEMAPS_ORDINARY_MAPS (set);
+  linemap_assert (begin <= goal
+                  && goal < begin + LINEMAPS_ORDINARY_USED (set));
+  
+  unsigned total_counted = 0;
+  unsigned counting_start, counting_end;
+  enum {
+    PENDING = 0,
+    COUNTING
+  } state = PENDING;
+
+  const char *goal_to_file = ORDINARY_MAP_FILE_NAME (goal);
+  const line_map_ordinary *map = begin;
+#if 1 /* caching & resuming (for performance) */
+  if (s_cache.to_file == goal_to_file
+      && begin <= s_cache.map && s_cache.map <= goal)
+    {
+   /* state         = PENDING; */
+      map           = s_cache.map;
+      total_counted = s_cache.total_counted;
+    }
+  else
+    {
+      s_cache.to_file       = goal_to_file;
+      s_cache.map           = NULL;
+      s_cache.total_counted = 0;
+    }
+#endif
+  for (; map < goal; ++map)
+    {
+      const line_map_ordinary *includer_map;
+      switch (state)
+        {
+        case PENDING:
+          if (goal_to_file != ORDINARY_MAP_FILE_NAME (map))
+            continue;
+          if (map->reason != LC_RENAME && map->reason != LC_LEAVE)
+            continue;
+#if 1 /* caching & resuming (for performance) */
+          if (begin < map)
+            {
+              s_cache.map           = map;
+              s_cache.total_counted = total_counted;
+            }
+#endif
+          state = COUNTING;
+          counting_start
+            = map->start_location >> map->m_column_and_range_bits;
+          break;
+        
+        default: /*case COUNTING:*/
+          includer_map = linemap_included_from_linemap (set, map);
+          if (! (map->reason == LC_RENAME
+              || map->reason == LC_ENTER && includer_map &&
+                 goal_to_file == ORDINARY_MAP_FILE_NAME (includer_map)
+          ))
+            continue;
+          counting_end
+            = map->start_line >> map->m_column_and_range_bits;
+          total_counted += counting_end - counting_start;
+          if (map->reason == LC_RENAME) {
+            counting_start
+              = map->start_location >> map->m_column_and_range_bits;
+            continue;
+          }
+          state = PENDING;
+          break;
+        }
+    }
+
+  if (COUNTING == state)
+    {
+      counting_end
+        = goal->start_line >> goal->m_column_and_range_bits;
+      total_counted += counting_end - counting_start;
+    }
+
+  return (int)(1 + total_counted);
+}
